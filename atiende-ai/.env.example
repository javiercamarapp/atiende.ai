# atiende.ai — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ─── Supabase ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── LLM (OpenRouter + OpenAI for embeddings) ──────────
OPENROUTER_API_KEY=sk-or-...
OPENAI_API_KEY=sk-...
# Feature flag — Phase 2 tool calling. Leave false until tools are migrated.
USE_TOOL_CALLING=false
# Optional: enable an LLM-as-judge sampler for response quality metrics.
ENABLE_LLM_JUDGE=false
# Optional: persist computed metrics to Supabase. Default false (memory only).
METRICS_PERSIST=false
# Optional: per-tenant daily LLM cost caps (USD).
# TENANT_DAILY_COST_SOFT_USD=5
# TENANT_DAILY_COST_HARD_USD=10
LOG_LEVEL=info

# ─── WhatsApp (Meta Cloud API) ──────────────────────────
WA_VERIFY_TOKEN=your-verify-token
WA_ACCESS_TOKEN=your-access-token
WA_APP_SECRET=your-app-secret
WA_SYSTEM_TOKEN=your-system-token
META_APP_ID=your-meta-app-id
NEXT_PUBLIC_META_CONFIG_ID=your-config-id

# ─── Voice (Retell + Deepgram + Telnyx) ────────────────
# Only required if a tenant enables the voice agent (premium plan).
RETELL_API_KEY=key_...
DEEPGRAM_API_KEY=your-deepgram-key
TELNYX_PHONE_NUMBER=+1...

# ─── Payments (Stripe) ─────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe price IDs per plan. Preferred over the legacy placeholders.
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PREMIUM=price_...
# Metered price for voice overage (MXN $5/min, aggregate=SUM).
# REQUIRED if premium checkouts are enabled.
STRIPE_VOICE_OVERAGE_PRICE_ID=price_...

# ─── Cache / Rate Limiting (Upstash Redis + QStash) ────
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your-redis-token
# Older code path also reads the REST variants below. Set the same values.
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token
# QStash — async webhook delivery. Required for the WhatsApp pipeline.
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=sig_...
QSTASH_NEXT_SIGNING_KEY=sig_...

# ─── Encryption (AES-256-GCM) ──────────────────────────
# REQUIRED in production. 32-byte key base64-encoded. Boot will fail if
# missing when the app tries to encrypt messages/PII.
MESSAGES_ENCRYPTION_KEY=base64-32-bytes
PII_ENCRYPTION_KEY=base64-32-bytes
CREDENTIAL_ENCRYPTION_KEY=base64-32-bytes

# ─── Google APIs ───────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-maps-key
# Calendar OAuth (optional — only if the Google Calendar integration is used)
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# GOOGLE_CLIENT_EMAIL=...
# GOOGLE_PRIVATE_KEY=...
# GOOGLE_PROJECT_ID=...

# ─── Email (Resend) ────────────────────────────────────
RESEND_API_KEY=re_...

# ─── Cron Job Auth ──────────────────────────────────────
CRON_SECRET=your-cron-secret

# ─── App URL ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# ─── Observability (optional) ──────────────────────────
# When unset, Sentry is disabled — no events are sent. The real DSN must
# never be committed; this file only documents the variable names.
# SENTRY_DSN=https://...@sentry.io/...
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ─── Third-party integrations (optional) ───────────────
# Only set the blocks for integrations a tenant actually uses.
# JINA_API_KEY=jina_...
# FACTURAPI_KEY=sk_live_...
# RAPPI_WEBHOOK_SECRET=...
# UBER_EATS_WEBHOOK_SECRET=...
# DIDI_WEBHOOK_TOKEN=...
# CLOUDBEDS_CLIENT_ID=...
# CLOUDBEDS_CLIENT_SECRET=...
# SOFTRESTAURANT_API_URL=...
# SOFTRESTAURANT_API_KEY=...
# INSURANCE_WORKER_URL=...
# INSURANCE_WORKER_SECRET=...
# WORKER_URL_BASE=...

# ─── Dev / Test only ───────────────────────────────────
# DISABLE_ATOMIC_UPSERT=1   # skip DB-level upsert guard in tests
