# atiende.ai — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ─── Supabase ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── LLM (OpenRouter + OpenAI for embeddings) ──────────
OPENROUTER_API_KEY=sk-or-...
OPENAI_API_KEY=sk-...

# ─── WhatsApp (Meta Cloud API) ──────────────────────────
WA_VERIFY_TOKEN=your-verify-token
WA_ACCESS_TOKEN=your-access-token
WA_APP_SECRET=your-app-secret
WA_SYSTEM_TOKEN=your-system-token
NEXT_PUBLIC_META_CONFIG_ID=your-config-id

# ─── Payments (Stripe) ─────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Cache / Rate Limiting (Upstash Redis) ──────────────
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your-redis-token

# ─── Google Maps ────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-maps-key

# ─── Email (Resend) ────────────────────────────────────
RESEND_API_KEY=re_...

# ─── Cron Job Auth ──────────────────────────────────────
CRON_SECRET=your-cron-secret

# ─── App URL ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Observability (optional) ──────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# ENABLE_LLM_JUDGE=false
# METRICS_PERSIST=false
